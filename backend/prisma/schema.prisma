generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId Int @id @default(autoincrement()) @map("user_id")

  hcaId              String    @unique @map("hca_id")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  email              String    @unique
  birthday           DateTime? @db.Date
  slackUserId        String?   @unique @map("slack_user_id")
  slackUsername      String?   @map("slack_username")
  verificationStatus String?   @map("verification_status")

  role String @default("user")

  onboardComplete Boolean   @default(false) @map("onboard_complete")
  onboardedAt     DateTime? @map("onboarded_at")

  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String?
  state        String?
  country      String?
  zipCode      String? @map("zip_code")

  airtableRecId String? @map("airtable_rec_id")

  hackatimeAccount     String?   @map("hackatime_account")
  hackatimeAccessToken String?   @map("hackatime_access_token")
  hackatimeStartDate   DateTime? @map("hackatime_start_date")

  referralCode     String? @unique @map("referral_code")
  referredByUserId Int?    @map("referred_by_user_id")
  referredBy       User?   @relation("Referrals", fields: [referredByUserId], references: [userId])
  referrals        User[]  @relation("Referrals")
  rafflePos        String? @map("raffle_pos")
  utmSource        String? @map("utm_source")

  isFraud      Boolean @default(false) @map("is_fraud")
  isSus        Boolean @default(false) @map("is_sus")
  ageOverride  Boolean @default(false) @map("age_override")
  adminComment String? @map("admin_comment") @db.VarChar(1000)

  timezone       String?   @map("timezone")
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  lastActiveDate DateTime? @map("last_active_date") @db.Date

  // Stamped once when we send the "you hit 15 approved hours — buy your ticket"
  // Loops email. Null means the email hasn't been sent; we never re-send.
  ticketQualifyEmailSentAt DateTime? @map("ticket_qualify_email_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects           Project[]
  sessions           UserSession[]
  hackatimeLinkOtps  HackatimeLinkOtp[]
  transactions       Transaction[]
  pinnedItem         PinnedItem?
  pinnedEvent        PinnedEvent?
  claimedSubmissions Submission[]        @relation("SubmissionClaimedBy")
  dailyActivity      UserDailyActivity[]

  @@index([currentStreak(sort: Desc), lastActiveDate(sort: Desc), userId], name: "users_streak_leaderboard_idx")
  @@map("users")
}

model UserDailyActivity {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  localDate DateTime @map("local_date") @db.Date
  seconds   Int
  qualified Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, localDate])
  @@index([userId, localDate(sort: Desc)])
  @@map("user_daily_activity")
}

model Project {
  projectId            Int          @id @default(autoincrement()) @map("project_id")
  userId               Int          @map("user_id")
  projectType          ProjectType  @map("project_type")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  approvedHours        Float?       @map("approved_hours")
  description          String?      @db.VarChar(500)
  hoursJustification   String?      @map("hours_justification") @db.Text
  nowHackatimeHours    Float?       @map("now_hackatime_hours")
  nowHackatimeProjects String[]     @map("now_hackatime_projects")
  playableUrl          String?      @map("playable_url")
  projectTitle         String       @map("project_title") @db.VarChar(30)
  repoUrl              String?      @map("repo_url")
  readmeUrl            String?      @map("readme_url")
  journalUrl           String?      @map("journal_url")
  screenshotUrl        String?      @map("screenshot_url")
  isLocked             Boolean      @default(false) @map("is_locked")
  adminComment         String?      @map("admin_comment") @db.VarChar(1000)
  // Fraud review integration: stores the external review platform's project UUID
  joeProjectId         String?      @map("joe_project_id")
  // null = not yet reviewed; true = passed; false = auto-rejected
  joeFraudPassed       Boolean?     @map("joe_fraud_passed")
  joeFraudReviewedAt   DateTime?    @map("joe_fraud_reviewed_at")
  joeTrustScore        Float?       @map("joe_trust_score")
  joeJustification     String?      @map("joe_justification") @db.Text
  joeOutcomeStatus     String?      @map("joe_outcome_status")
  joeOutcomeReason     String?      @map("joe_outcome_reason") @db.Text
  joeOutcomeRecordedAt DateTime?    @map("joe_outcome_recorded_at")
  user                 User         @relation(fields: [userId], references: [userId], onDelete: Cascade)
  submissions          Submission[]

  @@index([userId])
  @@map("projects")
}

model Submission {
  submissionId       Int                  @id @default(autoincrement()) @map("submission_id")
  projectId          Int                  @map("project_id")
  playableUrl        String?              @map("playable_url")
  screenshotUrl      String?              @map("screenshot_url")
  description        String?              @db.VarChar(500)
  repoUrl            String?              @map("repo_url")
  approvedHours      Float?               @map("approved_hours")
  hackatimeHours     Float?               @map("hackatime_hours")
  hoursJustification String?              @map("hours_justification") @db.Text
  // Reconciled final outcome of both gates (reviewer + fraud).
  // Stays `pending` until the state machine finalizes via SubmissionApprovalService.
  approvalStatus     ApprovalStatus       @default(pending) @map("approval_status")
  // Reviewer's independent decision. null = undecided, true = approve, false = reject.
  reviewPassed       Boolean?             @map("review_passed")
  // Raw reviewer analysis text — wrapped with boilerplate at finalization to build project.hoursJustification.
  reviewerAnalysis   String?              @map("reviewer_analysis") @db.Text
  // Reviewer's intent to send an email on finalization (honored when fraud-delayed finalization fires).
  pendingSendEmail   Boolean              @default(false) @map("pending_send_email")
  // True when fraud failed (`joeFraudPassed=false`), meaning the submission was silently
  // rejected without notifying the user. User-facing responses map such rows back to 'pending'
  // so fraud actors receive no feedback.
  silentReject       Boolean              @default(false) @map("silent_reject")
  reviewedBy         String?              @map("reviewed_by")
  reviewedAt         DateTime?            @map("reviewed_at")
  // When approvalStatus transitioned from pending to approved/rejected.
  finalizedAt        DateTime?            @map("finalized_at")
  airtableRecId      String?              @map("airtable_rec_id")
  // Reviewer claim/lock — tracks who currently has this submission open in
  // the review UI. claimHeartbeatAt is bumped while the page is open; once it
  // goes stale (no heartbeat for ~90s) the claim is treated as released so
  // the next reviewer can pick it up without manual intervention.
  claimedById        Int?                 @map("claimed_by_id")
  claimedAt          DateTime?            @map("claimed_at")
  claimHeartbeatAt   DateTime?            @map("claim_heartbeat_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  project            Project              @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  claimedBy          User?                @relation("SubmissionClaimedBy", fields: [claimedById], references: [userId], onDelete: SetNull)
  auditLogs          SubmissionAuditLog[]
  checklist          ReviewerChecklist?

  @@index([projectId])
  @@index([claimedById])
  @@map("submissions")
}

model SubmissionAuditLog {
  id            Int        @id @default(autoincrement())
  submissionId  Int        @map("submission_id")
  adminId       Int        @map("admin_id")
  action        String // "review" or "update"
  newStatus     String?    @map("new_status") // "approved", "rejected", or null for non-status updates
  approvedHours Float?     @map("approved_hours")
  changes       Json? // snapshot of fields changed
  createdAt     DateTime   @default(now()) @map("created_at")
  submission    Submission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  @@index([submissionId])
  @@index([adminId])
  @@map("submission_audit_logs")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

/// @deprecated Belongs to the archived mail module (see backend/archive/mail/).
/// No code currently writes or reads this table. Kept until the new emailing
/// module either reuses it or supplies a replacement; drop via migration then.
model EmailJob {
  id             String    @id @default(uuid())
  recipientEmail String
  subject        String
  status         String    @default("pending")
  scheduledFor   DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  metadata       Json?
  lockedBy       String?
  lockedAt       DateTime?
  attempts       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([recipientEmail])
  @@index([createdAt])
  @@index([scheduledFor])
  @@index([lockedBy])
  @@map("email_jobs")
}

model StickerToken {
  id         String    @id @default(uuid())
  email      String
  token      String    @unique
  rsvpNumber Int
  isUsed     Boolean   @default(false)
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([token])
  @@index([email])
  @@map("sticker_tokens")
}

model HackatimeLinkOtp {
  id        String    @id @default(uuid())
  userId    Int       @map("user_id")
  email     String
  otpCode   String    @map("otp_code")
  expiresAt DateTime  @map("expires_at")
  isUsed    Boolean   @default(false) @map("is_used")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([otpCode])
  @@map("hackatime_link_otps")
}

enum ProjectType {
  windows_playable
  mac_playable
  linux_playable
  web_playable
  cross_platform_playable
  hardware
  mobile_app
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model UsersAirtable {
  email     String    @unique @map("email")
  firstName String?   @map("first_name")
  lastName  String?   @map("last_name")
  code      Int?
  birthday  DateTime? @db.Date

  @@map("users_airtable")
}

model Shop {
  shopId      Int        @id @default(autoincrement()) @map("shop_id")
  slug        String     @unique @db.VarChar(50)
  description String?    @db.VarChar(500)
  isActive    Boolean    @default(true) @map("is_active")
  isPublic    Boolean    @default(true) @map("is_public")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  items       ShopItem[]

  @@map("shops")
}

model ShopItem {
  itemId       Int               @id @default(autoincrement()) @map("item_id")
  shopId       Int               @map("shop_id")
  name         String            @db.VarChar(100)
  description  String?           @db.VarChar(500)
  imageUrl     String?           @map("image_url")
  cost         Float
  regions      String[]          @default([])
  maxPerUser   Int?              @map("max_per_user")
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  shop         Shop              @relation(fields: [shopId], references: [shopId], onDelete: Cascade)
  transactions Transaction[]
  variants     ShopItemVariant[]
  pinnedBy     PinnedItem[]

  @@index([shopId])
  @@map("shop_items")
}

model ShopItemVariant {
  variantId    Int           @id @default(autoincrement()) @map("variant_id")
  itemId       Int           @map("item_id")
  name         String        @db.VarChar(100)
  cost         Float
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  item         ShopItem      @relation(fields: [itemId], references: [itemId], onDelete: Cascade)
  transactions Transaction[]

  @@index([itemId])
  @@map("shop_item_variants")
}

model Transaction {
  transactionId   Int              @id @default(autoincrement()) @map("transaction_id")
  userId          Int              @map("user_id")
  kind            TransactionKind  @default(ShopItem)
  itemId          Int?             @map("item_id")
  variantId       Int?             @map("variant_id")
  eventId         Int?             @map("event_id")
  itemDescription String           @map("item_description") @db.VarChar(500)
  cost            Float
  isFulfilled     Boolean          @default(false) @map("is_fulfilled")
  fulfilledAt     DateTime?        @map("fulfilled_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  user            User             @relation(fields: [userId], references: [userId], onDelete: Cascade)
  item            ShopItem?        @relation(fields: [itemId], references: [itemId], onDelete: Cascade)
  variant         ShopItemVariant? @relation(fields: [variantId], references: [variantId], onDelete: SetNull)
  event           Event?           @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([userId, eventId, kind], name: "uniq_user_event_kind")
  @@index([userId])
  @@index([itemId])
  @@index([variantId])
  @@index([eventId])
  @@map("transactions")
}

enum TransactionKind {
  ShopItem
  EventRsvp
  EventTicket
}

model GiftCode {
  id              String    @id @default(uuid())
  code            String    @unique
  email           String
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  itemDescription String    @map("item_description") @db.VarChar(500)
  imageUrl        String    @map("image_url")
  filloutUrl      String    @map("fillout_url")
  isClaimed       Boolean   @default(false) @map("is_claimed")
  claimedAt       DateTime? @map("claimed_at")
  /// @deprecated Written by the archived mail module (see backend/archive/mail/).
  /// No code currently writes this; the new emailing module should populate it
  /// or supply a replacement timestamp. Drop via migration once decided.
  emailSentAt     DateTime? @map("email_sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@index([email])
  @@map("gift_codes")
}

model ReviewerChecklist {
  id           Int        @id @default(autoincrement())
  submissionId Int        @unique @map("submission_id")
  checkedItems Json       @default("[]") @map("checked_items") // array of checked item indices
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  submission   Submission @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)

  @@map("reviewer_checklists")
}

model PinnedItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  itemId    Int      @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  item      ShopItem @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@index([itemId])
  @@map("pinned_items")
}

model Event {
  eventId       Int           @id @default(autoincrement()) @map("event_id")
  slug          String        @unique @db.VarChar(100)
  title         String        @db.VarChar(200)
  description   String?       @db.VarChar(1000)
  imageUrl      String?       @map("image_url")
  location      String?       @db.VarChar(300)
  country       String?       @db.VarChar(100)
  startDate     DateTime      @map("start_date") @db.Date
  endDate       DateTime      @map("end_date") @db.Date
  hourCost      Float         @map("hour_cost")
  // Minimum approved hours a user must have earned before they can buy a ticket.
  // Column name preserved from the old two-step RSVP/ticket flow.
  ticketThreshold Float?      @map("rsvp_cost")
  ticketCost    Float?        @map("ticket_cost")
  ticketEnabled Boolean       @default(false) @map("ticket_enabled")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  pinnedBy      PinnedEvent[]
  transactions  Transaction[]

  @@map("events")
}

model CommunityEvent {
  communityEventId String   @id @default(uuid()) @map("community_event_id")
  name             String   @db.VarChar(200)
  start            DateTime @db.Timestamptz(6)
  end              DateTime @db.Timestamptz(6)
  tagline          String?  @db.VarChar(300)
  joinInfo         String?  @map("join_info") @db.Text
  actionUrl        String?  @map("action_url") @db.VarChar(2000)
  actionLabel      String?  @map("action_label") @db.VarChar(100)
  description      String?  @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([start])
  @@map("community_events")
}

model PinnedEvent {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  eventId   Int      @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([eventId])
  @@map("pinned_events")
}

model GlobalSettings {
  id                  String    @id @default("global")
  submissionsFrozen   Boolean   @default(false) @map("submissions_frozen")
  submissionsFrozenAt DateTime? @map("submissions_frozen_at")
  submissionsFrozenBy String?   @map("submissions_frozen_by")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("global_settings")
}

model HistoricalMetric {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Timestamptz(6)
  metric    String   @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, metric])
  @@index([metric])
  @@map("historical_metrics")
}
